{
  "manifest_version": 3,
  "name": "Tidy Dia Bridge",
  "version": "0.1.0",
  "description": "Local-only bridge that lets dia-organizer create tab groups in Dia.",
  "permissions": ["tabs", "tabGroups", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:7321/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tidy Dia Bridge",
    "default_popup": "popup.html"
  }
}
